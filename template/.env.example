# ── LLM Gateway ───────────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint: LiteLLM proxy, Azure OpenAI, vLLM, TGI, etc.
LLM_GATEWAY_URL=https://llm-gateway.your-org.internal/v1
LLM_GATEWAY_KEY=sk-your-key-here

# ── Model aliases ──────────────────────────────────────────────────────────────
# These must match the model names your gateway exposes.
# Change here to swap models — no code changes needed anywhere.
MODEL_GENERAL=general
MODEL_CODE=coder
MODEL_FAST=fast

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# For local development with docker compose:
DATABASE_URL=postgresql://agent:agent@localhost:5432/agentdb
# For K8s / production — use a secret manager to inject this value.
